# Required Kalshi auth
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=replace-with-rotated-key-id
KALSHI_PRIVATE_KEY_PATH=./.certs/kalshi/trade-api.local.pem
# keep the Kalshi PEM in ./.certs/kalshi/trade-api.local.pem
# Alternative to file path (not recommended for long-term):
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----..."
# Optional dashboard deposit tracking from Kalshi web session:
KALSHI_WEB_USER_ID=
KALSHI_WEB_SESSION_COOKIE=
KALSHI_WEB_CSRF_TOKEN=
KALSHI_WEB_AUTH_STATE_PATH=./.kalshi-soccer-bot/kalshi-web-auth.json
INVESTED_START_DATE=2026-03-01T00:00:00Z

# Bot mode
DRY_RUN=true
POLL_SECONDS=10
TIMEZONE=America/New_York
LOG_LEVEL=info

# Strategy
MIN_TRIGGER_MINUTE=70
MIN_GOAL_LEAD=2
ANYTIME_LARGE_LEAD_MIN_GOAL_LEAD=3
ANYTIME_LARGE_LEAD_MAX_YES_PRICE=0.90
RETRY_UNTIL_MINUTE=80
STAKE_USD=1
ESTIMATED_WIN_PROBABILITY=0.92
FEE_BUFFER=0.02
POST80_START_MINUTE=80
POST80_MIN_GOAL_LEAD=1
POST80_MAX_YES_PRICE=0.90
# Optional explicit cap. If blank: ESTIMATED_WIN_PROBABILITY - FEE_BUFFER
MAX_YES_PRICE=

# Liquidity filters
MIN_VOLUME_24H_CONTRACTS=50
MIN_LIQUIDITY_DOLLARS=250

# Risk controls
MAX_OPEN_POSITIONS=20
MAX_DAILY_LOSS_USD=50

# Recovery sizing (safer than streak martingale)
RECOVERY_MODE_ENABLED=false
RECOVERY_STAKE_USD=2
RECOVERY_MAX_STAKE_USD=16

# Competitions (Kalshi names, comma separated)
# Use ALL to include every soccer competition currently available on Kalshi.
LEAGUES=ALL
# Exclude specific settlements/markets from dashboard records + metrics (comma separated)
IGNORE_SETTLEMENT_TICKERS=KXRECNCBILL-25-JUL05,KXRECNCBILL-25

# Optional Twilio WhatsApp alerts (leave blank to disable)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+1XXXXXXXXXX

# Monitor API auth (recommended if dashboard is exposed publicly)
# Leave blank to disable auth on /api/dashboard
MONITOR_API_TOKEN=

# Dashboard build/runtime config
# For local dev, leave DASHBOARD_API_BASE_URL blank and rely on the Angular proxy.
# For Netlify/static hosting, point this to your public monitor API base URL.
DASHBOARD_API_BASE_URL=
DASHBOARD_API_TOKEN=
SUPABASE_URL=https://zmofffvxlodwxjwzclma.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# 32-byte encryption key for per-user PEM storage. Generate your own:
# openssl rand -base64 32
PEM_ENCRYPTION_KEY=

# State
STATE_FILE=./data/state.json

# Runtime overrides
RUNTIME_OVERRIDES_FILE=./data/runtime-overrides.json
